ip() {
	JSON=curl "https://ipinfo.io/${1}";

	if [[ -e $(which jq) ]]; then
		echo $JSON | jq .
	else
		echo $JSON
	fi
}

tunnel-kill() {
	lsof -ti tcp:${1} | xargs kill -9
}

# Get size of folder
sizeof(){ du -hs $1 | awk '{print $1}'; }

# Get registrar function
registrar() {

	REGISTRAR=( $(whois $1 | grep -m 1 -i "Registrar Handle" | awk -F ":" '/: / { print $2}') );

	if [ -n "$REGISTRAR" ]; then
		whois $REGISTRAR;
	else
		echo 'Could not find registrar info';
	fi

}

#Fetch wp uploads folder from server
tmux_project() {
	PROJECT_DIR=$PWD

	tmux split-window -h
	tmux select-pane -t 1
	cd $PROJECT_DIR
	tmux resize-pane -R 35

	tmux new-window -a
	cd $PROJECT_DIR

	tmux select-window -t 1
}
