# Kubectl
. "${DOTFILES_DIR}/system/.alias.kubectl"

alias vim="nvim"
alias c="docker compose"

# Directory and file navigation/editing
alias md='mkdir -p'
alias rd='rmdir'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ll='ls -li'
alias la='ls -la'
alias lsd='ls -l | grep "^d"'
alias fs="sizeof"
alias pwdcp='pwd | pbcopy'
alias -g vr=" vim -R -u ~/.dotfiles/vim/.vimrc.more -"

# Find
alias fd='find . -type d -name'
alias ff='find . -type f -name'

# Git
alias gs='git status'
alias gss='git status -s'
alias gcl='git clone'
alias ga='git add'
alias gall='git add -A'
alias gm="git merge"
alias gp='git push'
alias gb='git branch'
alias gbd='git branch -D'
alias gpo='git push origin'
alias gpu='git push --set-upstream'
alias gl='git pull'
alias gf='git fetch && git rebase'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gcf='git checkout $(git branch -r | fzf)'
alias gls="git log --pretty=format:'%s'"
alias gll='git log --graph --pretty=oneline --abbrev-commit'
alias gg="git log --all --decorate --oneline --graph"
alias ggs="gg --stat"
alias gsl="git shortlog -sn"
alias gw="git whatchanged"
alias gd='git diff | nvim -R -'
alias gt="git tag"
alias gta="git tag -a"

# Tmux
alias tm='tmux new-session -A -s main'
alias txl='tmux ls'
alias txn='tmux new-session -A -s'
alias txa='tmux a -t'
alias txk='tmux kill-session -t'

# Misc
alias q='exit'
alias reload="source ~/.zshrc"
alias artisan='php artisan'
alias flush='dscacheutil -flushcache'

# Fasd
alias a='fasd -a'        # any
alias s='fasd -si'       # show / search / select
alias d='fasd -d'        # directory
alias f='fasd -f'        # file
alias sd='fasd -sid'     # interactive directory selection
alias sf='fasd -sif'     # interactive file selection
alias z='fasd_cd -d'     # cd, same functionality as j in autojump
alias zz='fasd_cd -d -i' # cd with interactive selection
alias vv='a -e vim'       # Open any file/dir with vim
