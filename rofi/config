rofi.modi:                           window,run
rofi.opacity:                        30
rofi.theme: solarized
#rofi.font: SFMono Nerd Font
rofi.lines: 15
rofi.columns:                        1
rofi.levenshtein-sort:               true
rofi.auto-select:                    false
rofi.combi-modi:                     window,run
rofi.fuzzy:                          true
rofi.separator-style:                solid
rofi.hide-scrollbar:                 true
rofi.fullscreen:                     false

rofi.kb-remove-to-eol:               Control+p
rofi.kb-accept-entry:                Control+m,Return,KP_Enter
rofi.kb-row-up:                      Up,Control+k,Shift+Tab,Shift+ISO_Left_Tab,Control+s
rofi.kb-row-down:                    Down,Control+j,Control+t

rofi.theme: /usr/share/rofi/themes/Arc-Dark.rasi
