[user]
	name = Magnus Hauge Bakke
	email = magnus.bakke@ncl.no
[github]
	user = Bakke
[color]
	ui = true
[push]
	default = current
[alias]
	shorty = status --short --branch
	commend = commit --amend --no-edit
	praise = blame
	undo = reset --soft HEAD~1
[grep]
	extendRegexp = true
[core]
	editor = nvim
	excludesfile = ~/.dotfiles/config/git/.gitignore
[pull]
	rebase = true
[advice]
	pushNonFastForward = false
	statusHints = false
[diff]
	mnemonicprefix = true
